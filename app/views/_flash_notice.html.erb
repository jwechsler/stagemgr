<!-- flash messages -->
<%- flash.each do |key, msg| -%>
  <%- unless msg.blank? %>
	  <div id="flash_<%= key %>">
	    <!-- p style="float:right;"><%= link_to_function 'X', "Effect.Fade('#{key}')" %></p -->
	    <p><%= msg %></p>
	    <div class="clear"></div>
	  </div>
  <% end %>
<%- end -%>
<% flash[:error] = flash[:errors] = flash[:notice] = nil %>
