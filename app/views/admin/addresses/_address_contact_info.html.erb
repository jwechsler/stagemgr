  <b><%=h address.first_name %>
  <%=h address.last_name %></b><br/>
  <%- if !address.line1.blank? -%><%=h address.line1 %><br/><%- end -%>
  <%- if !address.line2.blank? -%><%=h address.line2 %><br/><%- end -%>
  <%- if !address.city.blank? -%><%=h address.city %>, <%- end -%>
  <%- if !address.state.blank? -%><%=h address.state %> <%- end -%>
  <%=h address.zipcode %><br/>
  <%- if !address.email.blank? -%><i>Email: <%=h address.email %></i><br/><%- end -%>
  <%- if !address.phone.blank? -%><i>Phone: <%=h address.phone %></i><%- end -%>
