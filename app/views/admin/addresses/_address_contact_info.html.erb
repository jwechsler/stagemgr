<%- if address.nil? %>
  <b>UNKNOWN ADDRESS</b><br/>
<%- else %>
    <b><%= link_to address.full_name, [:admin, address] %></b><br/>
  <%- if !address.line1.blank? -%><%=h address.line1 %><br/><%- end -%>
  <%- if !address.line2.blank? -%><%=h address.line2 %><br/><%- end -%>
  <%- if !address.city.blank? -%><%=h address.city %>, <%- end -%>
  <%- if !address.state.blank? -%><%=h address.state %> <%- end -%>
  <%=h address.zipcode %><br/>
  <%- if !address.email.blank?%><i>Email: </i><%= mail_to address.email, permitted_to?(:view_email, :admin_addresses) ? address.email : "[send e-mail]" %><br/><%- end -%>
  <%- if !address.phone.blank? -%><i>Phone: <%=h address.phone %></i><br/><%- end -%>
  <%- memberships = Membership.find_all_by_address_id(address.id).select{|m| m.active?}
      if memberships.size > 0
        membership_list = memberships.map {|m| m.member_code }.join(',')
  %>
  <i>Member ID: </i><%= membership_list %><br/>
  <%- end %>
<%- end  %>