<%= f.inputs do %>
    <%= f.input :first_name, :required=>false %>
    <%= f.input :last_name %>
    <%= f.input :email %>
    <%= f.input :line1, :label=>"Street (line 1)", :required=>false %>
    <%= f.input :line2, :label=>"Street (line 2)", :required=>false %>
    <%= f.input :city, :required=>false %>
    <%= f.input :state, :required=>false %>
    <%= f.input :zipcode, :label=>"Zip Code", :required=>false %>
<%- end -%>

