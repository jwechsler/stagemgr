<% javascript :defaults, 'address' %>
<h1>New Audience Member</h1>

<%= simple_form_for [:admin, @address] do |f| %>
    <%= token_tag %>
    <%= render :partial => '/admin/addresses/form', :locals => {:f => f} %>
    <%= f.action :submit, :value => "Create" %>

<%- end -%>

<%= link_to 'Back', admin_addresses_path %>
