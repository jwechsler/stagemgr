<%= javascript :defaults, 'address' %>
<h1>Editing admin_address</h1>

<%= semantic_form_for [:admin, @address] do |f| %>
    <%= f.inputs do %>
        <%= render :partial => '/admin/addresses/form', :locals => {:f => f} %>
        <%= f.action :submit, :label => "Update" %>
    <%- end -%>
<%- end -%>
<%= link_to 'Show', admin_address_path(@address) %> |
<%= link_to 'Back', :admin_addresses %>
