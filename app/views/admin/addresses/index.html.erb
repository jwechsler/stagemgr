<h1>Listing admin_addresses</h1>

<table>
  <tr>
    <th></th>
    <th></th>
    <th></th>
  </tr>

<% @addresses.each do |address| %>
  <tr>
    <td><%= link_to 'Show', admin_address_path(address) %></td>
