.grid-x.grid-padding-x
  .small-12.cell
    .grid-x.grid-padding-x
      .small-4.cell
        =f.input :code
      .small-4.cell
        =f.input :type, :collection=>{"$ Off"=>AmountOffSpecialOffer,"% Off"=>PercentOffSpecialOffer, 'TktClass'=>TicketClassSpecialOffer, 'Buy X Get Y'=>BuyXGetYSpecialOffer}, :include_blank=>false
      .small-4.cell
        =f.input :status, :collection=>SpecialOffer::OFFER_STATUSES, :include_blank=>false
    .grid-x.grid-padding-x
      .small-6.cell
        %fieldset.fieldset
          %legend Criteria
          =f.input :limiting_model_type, :label=>"Restrict To", :include_blank=>false,
            :collection=>[ ['Any', nil],
              ['Theater', Theater.to_s],
        	    ['Production', Production.to_s],
        	    ['Performance', Performance.to_s] ]

          =f.input :limiting_id, :label=>"Limiting Code"



      .small-6.cell
        %fieldset.fieldset
          %legend Action
          =f.input :amount, :label=>"Discount"
          =f.input :change_ticket_class_code, :label=>"Set ticket class code"
          =f.input :buy_quantity, :label=>"Buy quantity (X)"
          =f.input :get_quantity, :label=>"Get free quantity (Y)"
    .grid-x.grid-padding-x
      .small-12.cell
        %fieldset.fieldset
          %legend Filters
          .grid-x.grid-padding-x
            .small-12.medium-6.cell
              =f.input :ticket_class_code, :label=>"Ticket Classes starting with"
              .grid-x.grid-padding-x
                .small-6.cell
                  =f.input :performance_start_range, input_html: {:class=>'date_picker'}, as: :string, :label=>"Performances on or after"
                .small-6.cell
                  =f.input :performance_end_range, input_html: {:class=>'date_picker'}, as: :string, :label=>"Performances on or before"

            .small-12.medium-6.cell
              %fieldset.fieldset
                %legend Restrict by Day of Week
                .grid-x.grid-padding-x
                  .cell.small-6
                    =f.input :restricted_monday, label:"Mondays", as: :boolean
                    =f.input :restricted_tuesday, label:"Tuesdays", as: :boolean
                    =f.input :restricted_wednesday, label:"Wednesdays", as: :boolean
                  .cell.small-6
                    =f.input :restricted_thursday, label:"Thursdays", as: :boolean
                    =f.input :restricted_friday, label:"Fridays", as: :boolean
                    =f.input :restricted_saturday, label:"Saturdays", as: :boolean
                    =f.input :restricted_sunday, label:"Sundays", as: :boolean
    .grid-x.grid-padding-x
      .small-12.cell
        %fieldset.fieldset
          %legend Use restrictions
          .small-6.cell
            =f.input :auto_start, :as=>:datetime_picker, :label=>"Activate at", input_html: {:class=>'date_picker'}
          .small-6.cell
            =f.input :auto_expire, input_html: {:class=>'date_picker'}, as: :string, :label=>"Expire on"

          .small-12.medium-6.cell
            =f.input :number_of_uses, :label=>"Maximum uses"
          .small-12.medium-6.cell
            =f.input :max_tickets_per_order, :label=>"Max tickets/order"
    .grid-x.grid-padding-x
      .small-12.cell
        =f.button :submit
        - unless f.object.new_record?
          %a.secondary.button{href: "#", onclick: "var f=this.closest('form'),m=f.querySelector('input[name=\"_method\"]');if(m)m.remove();f.action='#{duplicate_admin_special_offer_path(f.object)}';f.submit();return false;"} Clone as New Offer
