<h1>Special Offer</h1>

<%= semantic_form_for [:admin,  @special_offer], :url=>admin_special_offer_path do |f| %>
  <%= f.inputs do %>
    <%= render :partial => '/admin/special_offers/form', :locals=>{:f=>f} %>
  <%- end %>
<p>
  <%= f.submit 'Save' %>
</p>
<% end %>

<%= link_to 'Back', admin_special_offers_path %>
