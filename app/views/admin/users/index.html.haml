= content_for :title do
  Users
= content_for :breadcrumbs do
  %ul.breadcrumbs
    %li.current
      %a{:href=>'#'} Users

.grid-x
  .small-12.cell

    %table#user-listing{:data=>{:source=>"#{admin_users_path(format: :json)}"}}
      %thead
        %tr
          %th Email
          %th Last Access Date
          %th Logins
          %th Failed Logins
          %th
          %th
      %tbody

    = link_to 'New user', new_admin_user_path, :class=>'button'

= content_for :js do
  :javascript
    $(document).ready(function() {
      $('#user-listing').dataTable({
        dom: 'lf<"toolbar-buttons">rtip',
        stateSave: true,
        pageLength: 25,
        "processing": true,
        "serverSide": true,
        "ajax": $('#user-listing').data('source'),
        "pagingType": 'full_numbers',
        "language": {
          "lengthMenu" : "_MENU_",
          "search": "_INPUT_"
        },
        columns: [
          {data: 'email', className: 'all', render: $.fn.dataTable.render.emailResponsive()},
          {data: 'last_request', className: 'min-medium'},
          {data: 'logins', className: 'none'},
          {data: 'failed_logins', className: 'none'},
          {data: 'privs', className: 'min-medium'},
          {data: 'actions', className: 'all'},

        ]
      });
      // setupActiveSwitchOnDataTable('#user-listing',4)
    });
