= content_for :title do
  = "Exchange Order \##{@original_order.id}"
= content_for :breadcrumbs do
  %div.grid-x.grid-padding-x.collapse
    %div.small-10.cell
      %ul.breadcrumbs
        %li
          = link_to 'Existing Orders', admin_orders_path
        %li
          = link_to "Order \##{@original_order.id}"
        %li.current
          %a{:href=>'#'}= "Exchange"
    %div.small-2.cell
      = render '/admin/orders/status_bar', :order=>@original_order

%div.grid-x.grid-padding-x
  %fieldset.fieldset
    %legend Original Order
    = render '/admin/ticket_orders/detail', :ticket_order=>@original_order
%div.grid-x.grid-padding-x
  %div.small-12.cell
    %fieldset.fieldset
      %legend Exchange Order
      = simple_form_for [:admin, @original_order, @exchange_order], :html=>{:id=>'admin_ticket_order_form'}, :url=>admin_ticket_order_exchange_ticket_orders_path(@original_order) do |order_form|
        = token_tag
        = render partial: '/ticket_orders/ticket_order_javascript_fields', locals:{order_form: order_form}

        = render '/admin/ticket_orders/ticket_line_items_form', :order_form=>order_form, :allow_internal=>true
        = render '/admin/service_line_items/form', :order_form=>order_form
        = render '/admin/orders/billing_form', :order_form=>order_form, :allowed_payment_types=>@allowed_payment_types
        = order_form.input :notes, :input_html=>{:rows => 4}
        - if order_form.object.status == Order::NEW || order_form.object.status == Order::HOLD
          = order_form.submit 'Place Order', :disable_with=>'Processing...', :class=>'button'
