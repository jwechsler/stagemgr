= simple_form_for [:admin, @ticket_order], :html=>{:id=>'admin_ticket_order_form'} do |order_form|
  %div.row
    %div.columns.small-12.medium-8
      = render :partial=>'ticket_line_items_form', :locals=>{:order_form=>order_form}
    %div.columns.small-12.medium-4
      %div.status_label
        = @ticket_order.status

  = render :partial=>'/admin/orders/form', :locals=>{:order_form=>order_form}
