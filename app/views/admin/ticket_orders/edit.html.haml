= content_for :title do
  Ticket Order
= content_for :breadcrumbs do
  %div.row.collapse
    %div.small-10.columns
      %ul.breadcrumbs
        %li
          = link_to 'Existing Orders', admin_orders_path
        %li.current
          %a{:href=>'#'} Ticket Order
    %div.small-2.columns
      %span.postfix.info{:style=>"font-size:11px; line-height:31px; height:31px;"}
        = @ticket_order.status.upcase


= simple_form_for [:admin, @ticket_order], :html=>{:id=>'admin_ticket_order_form', :autocomplete=>"off"} do |order_form|
  %div.row
    %div.columns.small-12.medium-8
      = render 'ticket_line_items_form', :order_form=>order_form
    %div.columns.small-12.medium-4
      = render '/admin/addresses/quick_lookup', :f=>order_form
  %div.row
    %div.columns.small-12
      = render :partial=>'/admin/orders/form', :locals=>{:order_form=>order_form}
