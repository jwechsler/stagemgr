.nested-fields
  %div.row.line_item{ :price=>"#{f.object.ticket_class.try(:ticket_price)}", :ticket_type=>f.object.ticket_class.try(:ticket_type) }
    %div.small-3.columns
      = f.input_field :ticket_class_code, as: :autocomplete, url: autocomplete_ticket_line_item_ticket_class_code_admin_ticket_orders_path, 'data-autocomplete-fields'=>'{"performance_code":"#ticket_order_performance_code"}' , class: 'code-input'
    %div.small-2.columns
      = f.input_field :ticket_count, :class=>'ticket_count', :as=>:numeric
    %div.small-3.columns
      %span.price
        = f.object.try(:ticket_class).try(:ticket_type)=='Donation' ? f.input_field(:price_override, :class=>'price_override price', label: 'Override') : f.input_field(:price_override, :class=>'price', :value=>f.object.ticket_class.nil? ? 0.00 : f.object.ticket_class.ticket_price, :disabled=>'disabled')
    %div.small-3.columns
      %div.total{ :style=>'margin-top: .5em' }
        = to_currency f.object.total
    %div.small-1.columns
      = link_to_remove_association "Remove", f, :class=>'tiny alert button right'
