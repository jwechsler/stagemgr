/= /admin/ticket_orders/_ticket_line_items_form
.cell.small-12
  %h4= order_production.name
.cell.small-12
  = order_form.input :performance_code, :label=>'Performance', url: autocomplete_performance_performance_code_admin_ticket_orders_path, as: :autocomplete, :fields => {:production_id => '#production_id'}, id_element: '#performance_id', input_html: {'data-auto-focus'=>false  }
#ticket_line_items.small-12.cell
  -if order_production.has_reserved_seating?
    =render partial:"/admin/ticket_orders/reserved_tickets", locals: {order_form: order_form}
  -else
    =render partial:"/admin/ticket_orders/general_admission_tickets", locals: {order_form: order_form}


= content_for :js do
  :javascript
    function setup_submit_button(use_reserved_seats = "") {
      if ($('#production_status').val() == "Season Seating") {
        $('#hold_control').show();
      } else {
        $('#hold_control').hide();
      }
    }

    function performance_selected() {
      return $.trim($('#performance_id').val() || '') !== '';
    }

    function update_perf_submit_state() {
      var $btns = $('.order-submit-button, #hold_button');
      if (performance_selected()) {
        $btns.removeClass('disabled').attr('aria-disabled', 'false').css('pointer-events', '');
        $('#perf-required-hint').hide();
      } else {
        $btns.addClass('disabled').attr('aria-disabled', 'true').css('pointer-events', 'none');
        $('#perf-required-hint').show();
      }
    }

    $(document).ready(function() {
      setup_submit_button();

      if ($('#perf-required-hint').length === 0) {
        $('#ticket_order_performance_code').closest('.cell').append(
          '<small id="perf-required-hint" class="alert-color" style="display:none">' +
          'Select a performance from the dropdown to enable order actions.</small>'
        );
      }

      // User editing the autocomplete text invalidates any prior selection.
      $('#ticket_order_performance_code').on('input', function() {
        $('#performance_id').val('');
        update_perf_submit_state();
      });

      // Autocomplete writes #performance_id asynchronously on select; recheck
      // shortly after focus leaves the field so we observe the populated id.
      $('#ticket_order_performance_code').on('blur', function() {
        setTimeout(update_perf_submit_state, 200);
      });

      // Capture-phase guard runs before the inline onclick handlers on the
      // submit links (confirmSubmit / submitForm).
      document.addEventListener('click', function(e) {
        var target = e.target.closest ? e.target.closest('.order-submit-button, #hold_button') : null;
        if (target && !performance_selected()) {
          e.preventDefault();
          e.stopPropagation();
          e.stopImmediatePropagation();
          alert('Please select a performance from the dropdown before continuing.');
        }
      }, true);

      update_perf_submit_state();
    });
