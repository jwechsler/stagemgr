- reserved = ticket_order.performance&.production&.has_reserved_seating?
%div{id:"ticket-line-item-merge", "data-seat-assignments":ticket_order.seat_assignments, "data-reserved-seating": reserved}
  - if reserved
    - ticket_order.seats.each do |sa|
      - tc = sa.ticket_class
      - linked_tli = sa.ticket_line_item
      %div{class:'reserved-seat-entry',
           id:"reserved-seat-entry-#{sa.id}",
           'data-seat-assignment-id':sa.id,
           'data-seat-label':sa.seat&.location,
           'data-ticket-class-id':sa.ticket_class_id,
           'data-ticket-class-name':tc&.class_name,
           'data-ticket-price':tc&.ticket_price,
           'data-price-override':sa.price_override,
           'data-ticket-line-item-id':linked_tli&.id}
  - else
    - ticket_order.ticket_line_items.select{|tli| !tli.ticket_count.nil? && tli.ticket_count > 0}.each do |tli|
      %div{id:"ticket-line-item-merge-#{tli.ticket_class_id}", 'data-ticket-count':tli.ticket_count, 'data-ticket-line-item-id':tli.id, 'data-price-override':tli.price_override}
