<p>
Performance:
<%=order.performance.to_s %>
</p>

<table id='line_items'>
	<thead>
	<th>Ticket Class</th>
	<th>Ticket Count</th>
	</thead>
<% order.ticket_line_items.each do |line_item| %>
<% if line_item.ticket? then %><tr>
	<td><%=h line_item.ticket_class.to_s %></td>
	<td><%=h line_item.ticket_count %></td>
	</tr><% end %>
<% end %>
  <tr>
    <td></td>
    <td><%= order.ticket_line_items.map{|li| li.ticket_count }.sum %> -- Total Tickets</td>
  </tr>
</table>

<%= render :partial=>'/admin/orders/payments', :locals=>{:order=>order} %>
<p>
	Order Status:
	<%=h order.status %>
</p>
<p>
	Confirmation Code:
	<%=h order.payments.first.nil? ? "" : order.payments.first.confirmation_code %>
</p>
<p>
	Referral Code:
	<%=h order.referral_code %>
</p>
<p>
	Notes:
	<%=h order.notes %>
</p>
