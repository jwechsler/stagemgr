.grid-x
  .small-6.medium-3.cell
    Ticket Class
  .small-6.medium-3.cell
    \# Tix
  .small-6.medium-2.cell
    Price
  .small-3.medium-2.cell
    Total
  .small-3.medium-2.cell
    &nbsp;
= order_form.simple_fields_for :ticket_line_items do |tlif|  
  = render 'ticket_line_item_fields', f: tlif, :production_selector=>'#ticket_order_production_code', :performance_selector=>'#ticket_order_performance_code', input_html: {'data-auto-focus'=>true}
.links.grid-x
  .cell.small-12
    =link_to_add_association 'Add tickets', order_form, :ticket_line_items, :class=>'tiny button'
    &nbsp;
    %strong Order Total:
    %span#order_total $0.00
= content_for :js do
  :javascript
    $("#add-ticket-line-item").click(function() {
      setTimeout(function() {
        $(".recalculate-required").click(function() {
          setTimeout(function() {
            recalculate_ga_total()
          },20);
        });
      },0);
    });
