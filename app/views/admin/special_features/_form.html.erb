<%= semantic_form_for [:admin, @special_feature] do |f| %>
  <%= f.inputs do %>
    <%= f.input :short_name %>
    <%= f.input :description %>
    <%= f.input :status, :as=>:select, :collection=>SpecialFeature::SPECIAL_FEATURE_STATUSES, :include_blank=>false %>
  <%- end %>
  <%= f.actions %>

<% end %>
