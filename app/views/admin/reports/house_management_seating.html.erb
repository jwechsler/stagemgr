<div class="row"><div class="small-12 columns">
<h3>House Management Report <%= @date.to_s(:long) %></h3>

<table id="house_management_seating" class="report">
  <caption>
    <i>House Management Report, generated at <%= Time.now.to_s(:hour_min) %> on <%= Time.now %></i>
  </caption>
  <%= render :partial=>"generic", :locals=>{:headers=>@headers, :report_body=>@report_data, :summary=>@totals} %>
</table>
</div></div>
