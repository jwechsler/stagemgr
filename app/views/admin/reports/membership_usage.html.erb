<div class="row"><div class="small-12 columns">
<h3>Membership Usage (<%= @start_day %> through <%= @end_day %>)</h3>

<table id="membership_usage" class="report">
  <caption>
    <i>Membership Usage report, generated at <%= Time.now.to_s(:hour_min) %> on <%= Time.now %></i>
  </caption>
  <%= render :partial=>"generic", :locals=>{:headers=>@headers, :report_body=>@report_data, :summary=>@totals} %>
</table>
</div></div>
