<%- if !headers.nil? && headers.size > 0 then %>
  <thead>
<%- headers.each { |h| %>
  <th><%= if h.is_a?(Symbol) then
            h.to_s.titlecase.gsub(/_/, ' ')
          else
            h
          end %></th>
<%- } %>
</thead>
<%- odd_row = false
    report_body.each { |row|
%>
  <tr class="<%= 'odd' if odd_row %> <%= row[:display_class] if !row[:display_class].nil? %>">
    <%- odd_row = !odd_row
        headers.each { |h| %>
      <td class="<%= 'currency' if row[h].is_a?(Money) %> <%= 'numeric' if row[h].is_a?(Fixnum) || row[h].is_a?(Float) %>">
        <%= if row[h].is_a?(Money)
              number_to_currency(row[h])
            elsif row[h].is_a?(Time)
              row[h].to_s(:hour_min)
            else
              row[h]
            end %></td>
    <%- } %>
  </tr>

<%- } %>
<%- end %>