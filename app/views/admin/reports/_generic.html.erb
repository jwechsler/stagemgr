<thead>
<%- headers.each { |h| %>
  <th><%= if h.is_a?(Symbol) then
            h.to_s.titlecase.gsub(/_/, ' ')
          else
            h
          end %></th>
<%- } %>
</thead>
<%- odd_row = false
    report_body.each { |row|
%>
  <tr class="<%= 'odd' if odd_row %>">
    <%- odd_row = !odd_row
        headers.each { |h| %>
      <td class="<%= 'currency' if row[h].is_a?(Money) %> <%= 'numeric' if row[h].is_a?(Fixnum) %>">
        <%= if row[h].is_a?(Money)
              number_to_currency(row[h])
            elsif row[h].is_a?(Time)
              row[h].to_s(:hour_min)
            else
              row[h]
            end %></td>
    <%- } %>
  </tr>

<%- } %>
<tr class="report_summary_row <%= 'odd' if odd_row %>">
  <%- headers.each { |h| %>
    <td class="<%= 'currency' if summary[h].is_a?(Money) %> <%= 'numeric' if summary[h].is_a?(Fixnum) %>">
      <%= if summary[h].is_a?(Money)
            number_to_currency(summary[h])
          elsif summary[h].is_a?(Time)
            summary[h].to_s(:hour_min)
          else
            summary[h]
          end %></td>
  <%- } %>
</tr>