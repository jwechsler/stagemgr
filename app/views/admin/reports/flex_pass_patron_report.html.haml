.grid-x.grid-padding-x
  .small-12.cell
    %h3
      FlexPass Patron Report:  
      = @starting_date.to_s(:long)
      through
      = @ending_date.to_s(:long)
    %table.report
      %caption
        %i
          FlexPass Patron Report, generated at
          = Time.now.to_s(:hour_min)
          on
          = Time.now.to_date.to_s(:long)
      = render :partial=>"generic", :locals=>{:headers=>@headers, :report_body=>@report_data}
    - if @flex_pass_offer_names.present?
      %p.help_text
        Limited to:
        = @flex_pass_offer_names