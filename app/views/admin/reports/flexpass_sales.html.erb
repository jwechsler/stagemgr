<div class="grid-x grid-padding-x">
  <div class="small-12 cell">
    <h3><%= @flex_pass_offer.name %></h3>

    <table id="flexpass_sales_by_date" class="report">
      <caption>
        <i>Flexpass sales as of <%= Time.now.to_s(:hour_min) %> on <%= Time.now %></i>
      </caption>
      <%= render :partial=>"generic", :locals=>{:headers=>@headers, :report_body=>@report_data, :summary=>@totals} %>
    </table>
  </div>
</div>
