<h1>Daily Sales</h1>
<h2><%= @start_day.to_s(:long) %> - <%= @end_day.to_s(:long) %></h2>

<table id="daily_box_office_receipts" class="report">
  <caption>
    <i>Summarized Daily Sales, generated at <%= Time.now.to_s(:hour_min) %> on <%= Time.now %>
  </caption>
  <%= render :partial=>"generic", :locals=>{:headers=>@headers, :report_body=>@report_data, :summary=>@totals} %>
</table>
