= simple_form_for [:admin, festival], html: { multipart: true } do |f|
  = token_tag
  .grid-x.grid-padding-x
    .cell.small-8
      = f.input :name
      = f.input :url_name, label: 'URL name', hint: "Sets the landing page address (/festivals/<url name>). Lowercase letters, numbers, and hyphens only. Required when the landing page is enabled."
      = f.input :short_description, hint: "255 character max", input_html: { maxlength: 255 }
      = f.input :description, hint: "Long description (markdown enabled)", input_html: { rows: 6 }

      = f.input :status, collection: Festival::FESTIVAL_STATUSES, include_blank: false
      = f.input :landing_page_enabled, label: "Enable public landing page"

    .cell.small-4
      = f.input :box_office_image, label: "Box Office Image", as: :file, direct_upload: true, input_html: { data: { direct_upload_url: rails_direct_uploads_url } }
      = f.object.decorate.box_office_image if f.object.box_office_image.attached?

  = f.button :submit, class: 'button'
