- content_for :title do
  Theaters
- content_for :breadcrumbs do
  = render "shared/components/breadcrumb", items: [{ label: "Theaters" }]

.grid-x.grid-padding-x
  .small-12.cell
    %table#theater-listing{:data=>{:source=>"#{admin_theaters_path(format: :json)}"}}
      %thead
        %tr
          %th Name
          %th Home
          %th Theater Class
          %th Actions


  .small-12.cell
    =link_to 'New theater', new_admin_theater_path, :class=>'small button right'

= content_for :js do
  :javascript
    $(document).ready(function() {
      $('#theater-listing').dataTable({
        "processing": true,
        "serverSide": true,
        "stateSave": true,
        "ajax": $('#theater-listing').data('source'),
        "pagingType": 'full_numbers',
        "language": {
          "lengthMenu" : "_MENU_",
          "search": "_INPUT_"
        },
        columns: [
          {data: 'name', className: 'all'},
          {data: 'home', className: 'min-medium'},
          {data: 'theater_class', className: 'min-medium'},
          {data: 'actions', className: 'all', orderable: false},
        ],
        "ordering": false
      });
    });