<h1>Editing theater</h1>

<%= semantic_form_for([:admin,@theater], :html => { :multipart => true }) do |f| %>
  <%= f.inputs do %>
    <%= f.input :name %>
    <%= f.input :url %>
    <%= f.input :theater_class, :label=>"Class", :as=>:select, :collection=>Theater::THEATER_CLASSES %>
    <%= f.input :logo, :label=>"Theater Logo", :hint=>image_tag(f.object.logo.url(:thumb)) %>
  <%- end %>
  <%= f.actions %>
<% end %>

<%= link_to 'Back', admin_theaters_path %>
