<h1>New theater</h1>

<%= semantic_form_for([:admin, @theater], :html => {:multipart => true}) do |f| %>
    <%= f.semantic_errors %>
    <%= render :partial => '/theaters/form', :locals => {:f => f} %>
    <%= f.actions do %>
        <%= f.action :submit, :label => 'Create' %>
    <%- end %>
<% end %>

<%= link_to 'Back', admin_theaters_path %>
