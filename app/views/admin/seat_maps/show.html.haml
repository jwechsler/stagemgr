= content_for :title do
  Seat Map
= content_for :breadcrumbs do
  %ul.breadcrumbs
    %li
      %a{:href=>"#{admin_venues_path}"} Venues
    %li
      %a{:href=>"#{admin_venue_path(@venue)}"}= @seat_map.venue.name
    %li.current
      %a{:href=>'#'}= "Seat Map #{@seat_map.label}"

.row
  .columns.small-12
    %h4 Seating Geometry
    %img{:src=>@seat_map.base_image_map.url, :alt => "", :usemap=> '#seatingmap', :class=>'seatingmap'}
    %map{name:'seatingmap'}
      - @seat_map.seats.each do |seat|
        %area{shape:"rect", coords:"#{seat.origin_x},#{seat.origin_y},#{seat.origin_x+seat.width},#{seat.origin_y+seat.height}", href:"#?loc=#{seat.location}",alt:"#{seat.location}"}

= content_for :js do
  :javascript
    $(document).ready(function() {
      $('img#seatingmap').mapster();
    });