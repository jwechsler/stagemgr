<%= semantic_form_for [:admin, @default_ticket_class] do |f| %>
  <%= f.inputs do %>
    <%= f.input :class_code %>
    <%= f.input :class_name %>
    <%= f.input :ticket_type, :collection=>TicketClass::TICKET_TYPES, :include_blank=> false %>
    <%= f.input :ticket_price %>
    <%= f.input :ticketing_fee %>
    <%= f.input :web_visible %>
    <%= f.input :holds_seats, :default=>true %>
    <%= f.input :auto_attach %>
    <%= f.input :software_managed %>
    <%= f.input :minutes_before_show %>

  <%- end %>
  <%= f.actions %>
<%- end %>
