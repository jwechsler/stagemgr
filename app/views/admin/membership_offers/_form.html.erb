<%= form_for [:admin, @membership_offer] do |f| %>
  <%= f.error_messages %>
  <p>
    <%= f.label :name %><br />
    <%= f.text_field :name %>
  </p>
  <p>
    <%= f.label :recurring_cost %><br />
    <%= f.text_field :recurring_cost %>
  </p>
  <p>
    <%= f.label :email_html %><br />
    <%= f.text_area :email_html %>
  </p>
  <p>
    <%= f.label :interval_in_months %><br />
    <%= f.text_field :interval_in_months %>
  </p>
  <p><%= f.submit %></p>
<% end %>
