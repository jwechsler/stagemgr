<% title "Admin/Membership Offers" %>

<table>
  <tr>
    <th>ID</th>
    <th>Name</th>
    <th>Recurring Cost</th>
    <th>On Sale</th>
  </tr>
  <% for membership_offer in @membership_offers %>
    <tr>
      <td><%= membership_offer.id %></td>
      <td><%= membership_offer.name %></td>
      <td class="currency"><%= number_to_currency(membership_offer.recurring_cost) %></td>
      <td><%= membership_offer.on_sale %>
      <td><%= link_to "Show", [:admin, membership_offer] %></td>
      <td><%= link_to "Edit", edit_admin_membership_offer_path(membership_offer) %></td>
      <td><%= link_to "Destroy", [:admin, membership_offer], :confirm => 'Are you sure?', :method => :delete %></td>
    </tr>
  <% end %>
</table>

<p><%= link_to "New Membership Offer", new_admin_membership_offer_path %></p>
