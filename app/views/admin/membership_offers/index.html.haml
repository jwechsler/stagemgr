= content_for :title do
  Membership Offers
= content_for :breadcrumbs do
  = render "shared/components/breadcrumb", items: [{ label: "Membership Offers" }]
.grid-x
  .small-12.cell
    %table#membership-offer-listing{:data=>{:source=>"#{admin_membership_offers_path(format: :json)}"}}
      %thead
        %tr
          %th Name
          %th On Sale to Public
          %th Type
          %th
      %tbody

    = link_to "New Membership Offer", new_admin_membership_offer_path, :class=>'button' if can? :create, MembershipOffer

= content_for :js do
  :javascript
    $(document).ready(function() {
      $('#membership-offer-listing').dataTable({
        "processing": true,
        "serverSide": true,
        "ajax": $('#membership-offer-listing').data('source'),
        "pagingType": 'full_numbers',
        "language": {
          "lengthMenu" : "_MENU_ entries"
        },
        columns: [
          {data: 'name'},
          {data: 'on_sale'},
          {data: 'membership_type'},
          {data: 'status'},
        ]
      });


    });

