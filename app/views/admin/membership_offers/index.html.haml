= content_for :title do
  Membership Offers
= content_for :breadcrumbs do
  %ul.breadcrumbs
    %li.current
      %a{:href=>'#'} Membership Offers

.row
  .small-12.columns
    %table#membership-offer-listing
      %thead
        %tr
          %th Name
          %th Recurring Cost
          %th On Sale
          %th
      %tbody
        - for membership_offer in @membership_offers
          %tr
            %td= link_to membership_offer.name, [:admin, membership_offer]
            %td.currency= number_to_currency(membership_offer.recurring_cost)
            %td= membership_offer.on_sale
            %td
              .button-bar
                %ul.button-group
                  %li= link_to("Edit", edit_admin_membership_offer_path(membership_offer), :class=>"tiny button") if permitted_to? :edit, :admin_membership_offers
                  %li= link_to("Destroy", [:admin, membership_offer], :confirm => 'Are you sure?', :method => :delete, :class=>"tiny alert button") if permitted_to? :destroy, :admin_membership_offers
                %ul.button-group
                  - if membership_offer.active?
                    = link_to "Create Order", new_admin_membership_offer_order_path(membership_offer), :class=>'tiny button'
                  - else
                    %a.tiny.button.disabled{:href=>'#'} Create Order
    = link_to "New Membership Offer", new_admin_membership_offer_path, :class=>'button' if permitted_to? :create, :admin_membership_offers
