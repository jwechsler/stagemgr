%tr
  %td= service_line_item.internal_description.blank? ? service_line_item.description : service_line_item.internal_description
  %td.currency= number_to_currency(service_line_item.amount)
  %td.currency= number_to_currency(service_line_item.facility_fee)
  %td
    - if service_line_item.persisted? && service_line_item.amount.to_f.zero? && service_line_item.facility_fee.to_f > 0 && (can? :modify_service_items, service_line_item.order)
      = ui_button 'Delete', admin_service_line_item_path(service_line_item), size: :tiny, variant: :alert, method: :delete, data: { confirm: "Delete this facility fee? This cannot be undone." }
