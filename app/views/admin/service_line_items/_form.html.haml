%br
#service_line_items
  .grid-x
    .small-8.cell
      = label("service_template", "Service Charge")
    .small-4.cell
      &nbsp;
    .small-8.cell
      = collection_select("choice", "service_template", ServiceItemTemplate.selectable, :id, :name_and_description)
    .small-4.cell
      &nbsp
  
  = order_form.simple_fields_for :service_line_items do |slif|
    = render 'service_line_item_fields', f: slif
  .links
    = link_to_add_association "Add Service Charge", order_form, :service_line_items, :class=>"button tiny"

= content_for :js do
  :javascript
    $(function() {
      $(".autohide").hide()
    });

    var response;
    var query;
    var allow_sli_edits = #{can? :modify_service_items, Order}
    $(document).on("fields_added.nested_form_fields", function(event, param) {
      if (param.object_class == "service_line_item") {
        var indx = param['added_index'];

        data_url = "#{admin_service_item_template_path('a')}".slice(0,-1) + $("#choice_service_template").val() + ".json";
        var query = $.getJSON(data_url, function (data) {
          var description = data['internal_description']
          var amount_v = parseFloat(data['amount'],0)
          var amount = Math.max(amount_v.toFixed(2),0)
          var fee_v = parseFloat(data['facility_fee'])
          var fee = fee_v.toFixed(2)
          $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][description]\"]").val(description);
          $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][description]\"]").closest('.cell').find("span.noneditable").text(description)
          if (amount_v < 0) {
            $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][amount]\"]").closest('.amount_field').show()
            $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][amount]\"]").closest('.cell').find("span.noneditable").hide()
          } else {
            $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][amount]\"]").closest('span').hide()
            $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][amount]\"]").closest('.cell').find("span.noneditable").show()
          }
          $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][amount]\"]").val(amount)
          $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][amount]\"]").closest('.cell').find("span.noneditable").html("Amount<br>" + amount_v.toFixed(2))
          $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][facility_fee]\"]").val(fee)
          $("[name*=\"[service_line_items_attributes]["+indx.toString()+"][facility_fee]\"]").closest('.cell').find("span.noneditable").text(fee)
        });
      }
    });
