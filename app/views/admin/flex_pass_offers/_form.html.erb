<%= f.inputs do %>
  <%= f.input :name %>
  <%= f.input :price %>
  <%= f.input :number_of_tickets %>
  <%= f.input :payout_per_ticket %>
  <%= f.input :short_description %>
  <%= f.input :description, :input_html=>{ :rows=>6} %>
  <%= f.input :active %>
  <%= f.input :theater, :as=>:select, :collection => Theater.find_all_by_status (['Active', 'Private']) %>
  <%= f.input :exclude_theater %>
  <%= f.input :web_visible, :label=>"Redeem immediately" %>
<%- end -%>