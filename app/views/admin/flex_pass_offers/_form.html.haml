= simple_form_for [:admin, flex_pass_offer] do |f|
  = token_tag
  .grid-x.grid-padding-x
    .cell.small-12
      = f.input :name
      %h5 Tags
      = render 'admin/tags/tag_input', f: f, autocomplete_url: autocomplete_tag_admin_flex_pass_offers_path
    .cell.small-6.medium-3
      = f.input :price, input_html: { step: '0.01' }
    .cell.small-6.medium-3
      = f.input :number_of_tickets
    .cell.small-6.medium-3
      = f.input :use_ticket_class_code, :as=>:select, :collection=>DefaultTicketClass.all.map{|tc| tc.class_code}
    .cell.small-6.medium-3
      = f.input :maximum_uses_per_production

    .cell.small-12.medium-6
      = f.input :short_description
    .cell.small-12.medium-6
      = f.input :code_prefix
  
    .cell.small-12
      %fieldset.fieldset
        %legend Payout Info
        .grid-x.grid-padding-x
          .cell.small-12.medium-4
            = f.input :flat_payout, input_html: { step: '0.01' }
          .cell.small-12.medium-4
            = f.input :spiff, input_html: { step: '0.01' }
          .cell.small-12.medium-4
            = f.input :facility_fee, input_html: { step: '0.01' }

    .cell.small-12
      = f.input :description, :input_html=>{ :rows=>6}
 
    .cell.small-6
      = f.input :active
    .cell.small-6
      = f.input :on_sale_to_public
    .cell.small-12
      %fieldset.fieldset
        %legend Use Restrictions
        .grid-x.grid-padding-x
          .cell.small-12.medium-4
            = f.input :months_till_expiration
          .cell.small-12.medium-4
            = f.association :festival, :label=>"Restrict to festival", :as=>:select, :include_blank=>true, :collection=>Festival.order(:name)
          .cell.small-12.medium-4
            = f.input :treat_as_festival_pass, :label=>"Treat as festival pass (legacy)"
          .cell.small-12.medium-4
            = f.association :theater, :label=>"Restrict redemption to", :as=>:select, :collection=>Theater.where("status in (?)", ['Active', 'Private'])
            = f.input :exclude_theater, :label=>"Exclude selected theater"
    .cell.small-12
      = f.input :redeem_immediately, :label=>"Redeem immediately"
      = f.button :submit, :class=>'button'
