<h1>New flex_pass_offer</h1>

<% form_for([:admin, @theater, @flex_pass_offer]) do |f| %>
  <%= f.error_messages %>

  <%= f.hidden_field :theater_id %>
  <p>
    <%= f.label :price %><br />
    <%= f.text_field :price %>
  </p>
  <p>
    <%= f.label :number_of_tickets %><br />
    <%= f.text_field :number_of_tickets %>
  </p>
  <p>
    <%= f.submit 'Create' %>
  </p>
<% end %>

<%= link_to 'Back', admin_flex_pass_offers_path %>