<div id="order_task_suppressions" class="formtastic_indented">
  <%- unless f.object.order_task_suppressions.empty? %>
  <table>
    <tr>
      <th>Task Type</th>
      <th>Method</th>
      <th></th>
    </tr>
    <%= f.fields_for :order_task_suppressions do |sup| %>
      <%= render :partial=>'show_order_task_suppression', :locals=>{:f=>sup} %>
    <%- end %>

  </table>
  <%- end %>
  <%= add_child_link "Add a task suppression", :order_task_suppressions %>
  <br/>
  <%= new_child_fields_template(f, :order_task_suppressions) %>
</div>