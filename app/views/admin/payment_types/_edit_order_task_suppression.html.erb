<tr class="order_task_suppressions">
  <td>
    <%= f.input(:task_type,
      :as=>:select,
      :collection=>$SERVER_CONFIG['allowed_order_task_suppressions'].keys.uniq)%>
  </td>
  <td>
  <%= f.input(:method_name,
      :as=>:select,
      :collection=>$SERVER_CONFIG['allowed_order_task_suppressions'].keys.map { |k| $SERVER_CONFIG['allowed_order_task_suppressions'][k] }.flatten.sort)
       %>
  </td>
  <td><%- unless f.object.new_record? %>
            <!-- For existing records we add a checkbox to be able to delete records. -->
            <%= f.label :_destroy,  "Remove: " %>
            <%= f.check_box :_destroy %>
          <% end %></td>
</tr>
