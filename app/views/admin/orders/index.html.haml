= content_for :title do
  Existing Orders
= content_for :breadcrumbs do
  %ul.breadcrumbs
    %li.current
      %a{:href=>'#'} Orders

.row
  .small-12.columns
    %table#order-listing{:data=>{:source=>"#{raw admin_orders_path(format: :json)}"}}
      %thead
      
        %th ID
        %th Code
        %th Name
        %th Status
        %th Visits
        %th Total
        %th Description
      %tr.filters
      %tbody

= content_for :js do
  :javascript
    'use strict';
    
    $(document).ready(function() {
      var oListing;

      oListing = $('#order-listing').DataTable({
        "stateSave": true,
        "responsive": true,
        "processing": true,
        "serverSide": true,
        "searching": false,

        "ajax": $('#order-listing').data('source'),
        "lengthMenu": [10, 25, 50, 100],
        "language": {
          "lengthMenu" : "_MENU_",
        },
        "columns": [
          {data: 'id'},
          {data: 'code'},
          {data: 'name'},
          {data: 'status'},
          {data: 'visits'},
          {data: 'total'},
          {data: 'description'},
        ],
      });
    
      yadcf.init(oListing, [
        { column_number: 0, filter_type: "text", filter_delay: 500 },
        { column_number: 1, filter_type: "text", filter_delay: 500, orderable: false },
        { column_number: 2, filter_type: "text", filter_delay: 500, orderable: false },
        { column_number: 3, filter_type: "select", data: [#{raw Order::ORDER_STATUSES.map{|s| "'#{s}'"}.join(',')}] },
      ]);
