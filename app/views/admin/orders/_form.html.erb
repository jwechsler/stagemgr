<% javascript :defaults, 'delegate', 'jquery-1.3.2.min', 'jquery.autocomplete', 'box_office_order' %>

<%= error_messages_for :order %>

<% form_for [:admin,@order] do |order_form| -%>

  <% content_for :jstemplates do -%>
  <%= "var line_item='#{generate_template(order_form, :line_items)}'" %>
  <% end -%>

  <p>
  <%= order_form.label :production_code %>
  <%= order_form.text_field :production_code, 
                   :class=>'autocomplete_prcode', 
                   :autocomplete_url=>autocomplete_production_code_admin_orders_path,
                   :size=>10 %>
  </p>
  <p>
  <%= order_form.label :performance_code %>
  <%= order_form.text_field :performance_code, 
                   :class=>'autocomplete_pcode', 
                   :autocomplete_url=>autocomplete_performance_code_admin_orders_path,
                   :size=>10 %>
  </p>
  <table id='line_items'>
    <thead>
      <th>Ticket Class</th>
      <th>Ticket Count</th>
      <th>Price Override</th>
      <th>Total</th>
    </thead>
  <% order_form.fields_for :line_items do |line_item_form| %>
  <%= render :partial => 'line_item', :locals => { :f => line_item_form } %>
  <% end %>
  </table>
  <%= link_to 'Add a line item', '#line_item', :class => "add_nested_item", :rel => "line_items" %>
<p>
<%= order_form.label :first_name %>
<%= order_form.text_field :first_name %>
</p>
<p>
<%= order_form.label :last_name %>
<%= order_form.text_field :last_name %>
</p>

<p>
<%= order_form.label :card_type %>
<%= order_form.select :card_type, ['Cash'] + ActiveRecord::Validations::ClassMethods::DEFAULT_CREDIT_CARD_TYPES.values.sort - ['invalid','Diners Club'] %>
</p>
<p>
<%= order_form.label :card_number %>
<%= order_form.text_field :card_number %>
</p>
<p>
Expiration Month/Year
<%= order_form.select :card_expiration_month, 1.upto(12).map{|n|['%02d' % n,n]} %>
<%= order_form.select :card_expiration_year, Date.today.year.upto(Date.today.year+12).to_a %>
</p>
<p>
<%= order_form.label :card_verification_number %>
<%= order_form.text_field :card_verification_number, :size=>4 %>
</p>
<p>
	Billing Address:
</p>
<p>
<%= order_form.label :billing_address_line1, 'Address Line1' %>
<%= order_form.text_field :billing_address_line1 %>
</p>
<p>
<%= order_form.label :billing_address_line2, 'Address Line2' %>
<%= order_form.text_field :billing_address_line2 %>
</p>
<p>
<%= order_form.label :billing_address_city, 'City' %>
<%= order_form.text_field :billing_address_city %>
</p>
<p>
<%= order_form.label :billing_address_state, 'State/Province/Region' %>
<%= order_form.text_field :billing_address_state %>
</p>
<p>
<%= order_form.label :billing_address_zipcode, 'ZIP/Postal Code' %>
<%= order_form.text_field :billing_address_zipcode %>
</p>
<p>
<%= order_form.label :email %>
<%= order_form.text_field :email %>
</p>
<p>
	<%= order_form.label :confirmation_code %>
	<%= order_form.text_field :confirmation_code %>
	( For Manually Processing Only )
</p>
<p>
	<%= order_form.label :referral_code %>
	<%= order_form.text_field :referral_code %>
</p>

<p>
	Order Status: <%=order_form.object.status || 'New' %>
</p>
<p>
  <%= order_form.label :notes %>
  <%= order_form.text_area :notes, :rows=>3 %>
<p>
<% if order_form.object.status.nil? || order_form.object.status == Order::HOLD%>
<%= order_form.submit "Hold" %>
<%= order_form.submit "Process Online" %>
<%= order_form.submit "Manually Processed" %>
<% end %>
<% unless order_form.object.new_record? %>
<%= link_to 'Cancel Order', cancel_admin_order_path(order_form.object), :confirm => "Are you sure?", :method=>:post %>
<% end %>
</p>
<% end -%>

