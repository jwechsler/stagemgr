<% javascript :defaults, 'delegate', 'jquery-1.4.2.min', 'jquery.autocomplete', 'box_office_order' %>

<%= error_messages_for :order %>

<%= form_for [:admin,@order] do |order_form| -%>

<%- if @order.ticket_line_items.size > 0 -%>
	<%= render :partial=>'/admin/orders/ticket_line_items_form', :locals=>{:order_form=>order_form}%>
<%- end -%>

<%- if @order.flex_pass_line_items.size > 0 -%>
	<%= order_form.fields_for :flex_pass_line_items do |flex_pass_line_item_form| %>
		<%= render :partial => '/admin/orders/flex_pass_line_item_form', :locals => { :f => flex_pass_line_item_form } %>
	<% end %>
<%- end -%>

<%= render :partial => '/admin/orders/form', :locals=>{:order_form=>order_form} %>

<p>
  <%= order_form.submit 'Hold', :disable_with => 'Processing...' if order_form.object.status == Order::NEW || order_form.object.status == Order::HOLD %>
  <%= order_form.submit 'Place Order', :confirm => "Process this order?", :disable_with => 'Processing...' if order_form.object.status == Order::NEW || order_form.object.status == Order::HOLD %>
  <%= if order_form.object.status == Order::HOLD || order_form.object.status == Order::PROCESSING
        link_to 'Cancel Order', cancel_admin_order_path(order_form.object), :confirm => "Are you sure?", :method=>:post 
      end %>
</p>

<%- if !@order.audits.empty? -%>
<h3>Change history for <%= @order.id %></h3>
<ul>
<% @order.audits.each do |revision| %>
    <%= revision.user_id.nil? ? "[Web" : "[#{User.find_by_id(revision.user_id).username}" %>, <%= distance_of_time_in_words_to_now revision.created_at %> ago] 
    <%- if revision.action == "create" -%>
      created
    <%- else -%>
      <%= revision.action %>, 
      <% revision.audited_changes.each do |fld,changes| %>
        <%= "#{fld} changed to #{changes[1]}" %>
      <%  end %>
        
    <%- end -%>
      
    <BR>
<% end %>
</ul>
<%- end -%>

<% end -%>
