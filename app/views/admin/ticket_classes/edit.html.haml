= content_for :breadcrumbs do
  %ul.breadcrumbs
    %li= link_to "Theaters", admin_theaters_path
    %li= link_to @production.theater.name, admin_theater_path(@production.theater)
    %li= link_to @production.name, admin_theater_production_path(@production.theater, @production)
    %li= link_to 'Ticket Classes', admin_theater_production_ticket_classes_path(@theater,@production)
    %li.current
      %a{:href=>'#'}= @ticket_class.class_code
.grid-x.grid-padding-x
  .cell.small-12
    = content_for :title do
      Editing Ticket Class
      = @ticket_class.class_code
      on
      = @production.name
    %h3 Editing Ticket Class
    = render :partial => 'form', :locals=>{theater: @theater, production: @production, ticket_class: @ticket_class}
