.row
  .small-4.columns
    = f.input_field :ticket_count, :as=>:select, :collection=>1.upto(20), :label=>"Quantity", :required=>false, :include_blank=>false
  .small-5.columns
    %p= f.object.flex_pass_offer.name
  .small-3.columns
    %p= number_to_currency(f.object.flex_pass_offer.price)
    = f.input :flex_pass_offer_id, :as=>:hidden
