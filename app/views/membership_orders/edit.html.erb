<%= javascript :defaults, 'delegate', 'jquery-1.4.2.min', 'jquery.autocomplete', 'membership_order' %>

<h1><%= @order.membership_offer.name %></h1>

<%- if !@order.membership_offer.html_description.blank? %>
  <p><%= raw @order.membership_offer.html_description %></p>
<%- end %>
<%= semantic_form_for @order do |order_form| %>
  <%= order_form.error_messages %>
  <%= order_form.inputs :class=>"order" do %>
    <%= order_form.semantic_fields_for :membership_line_items do |mlif| %>
      <% mlif.inputs do %>
        <%= mlif.input :membership_offer_id, :as=>:hidden %>
      <%- end %>
    <%- end %>
    <%= order_form.error_messages %>
    <%= order_form.hidden_field :status %>
    <%= render :partial=>'/orders/address', :locals=>{:order_form=>order_form} %>
  <%- end %>
  <%= order_form.submit "Checkout", :action=>:confirm, :disable_with => 'Processing...' if order_form.object.status == Order::NEW %>
<%- end %>
