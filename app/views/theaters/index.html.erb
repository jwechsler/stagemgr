<h1>Listing theaters</h1>

<table>
  <tr>
    <th>Name</th>
    <th>Url</th>
    <th>Logo</th>
    <th>Theater class</th>
    <th>Status</th>
  </tr>

<% @theaters.each do |theater| %>
  <tr>
    <td><%=h theater.name %></td>
    <td><%=h theater.url %></td>
    <td><%=h theater.logo %></td>
    <td><%=h theater.theater_class %></td>
    <td><%=h theater.status %></td>
    <td><%= link_to 'Show', theater %></td>
    <td><%= link_to 'Edit', edit_theater_path(theater) %></td>
    <td><%= link_to 'Destroy', theater, :confirm => 'Are you sure?', :method => :delete %></td>
  </tr>
<% end %>
</table>

<br />

<%= link_to 'New theater', new_theater_path %>