<style>
.day_list
{
float:left;
margin:0;
padding:0;
border:1px solid #C9C9C9;
width:300px;
}
.day_list ul
{
width:100%;
}
.day_list li
{
list-style:none;
margin:0px;
padding:0px;
}

.day_list_nav
{
float:left;
margin:0;
padding:0;
background:#8080B2;
}
.day_list_nav a
{
color:#FFFFFF;
}
.day_list_nav .previous
{
float:left;
}
.day_list_nav .next
{
float:right;
}

.day_list .day-header
{
float:left;
width:100%;
background:#D9D9D9;
}
.day_list .production
{
background:#FFFFFF;
margin:0px 15px 0px;
}

</style>
<ul class='day_list' >
<%= render :partial=>'day_list_navigation', :locals=>{:first_date=>@start_date,:last_date=>@end_date} %>
<% (@start_date..@end_date).each do |date| %>
<%= render :partial=>'production_list_for_day', :locals=>{:date=>date,:productions=>@productions} %>
<% end %>
<%= render :partial=>'day_list_navigation', :locals=>{:first_date=>@start_date,:last_date=>@end_date} %>
</ul>