<%- unless production.first_performance_at.nil? %>
  <p class="production_dates">
    <%- unless production.status == Production::PRESALE %>
      <%- if production.now_playing? %>
          Now playing
          <%= "through #{production.closing_at.strftime('%B %d, %Y ')}" unless production.closing_at.nil? %>
      <%- else %>
        <%= production.first_performance_at.strftime('%B %d, %Y')%>
        <%= "through #{production.closing_at.strftime('%B %d, %Y ')}" unless production.closing_at.nil? || (production.first_performance_at == production.closing_at) %>
      <%- end %>

    <%- else %>
      <%= soft_date(production.first_performance_at) %>
      <%= "through #{soft_date(production.closing_at)}" unless (production.closing_at.nil? || soft_date(production.first_performance_at) == soft_date(production.closing_at)) %>
    <%- end %>
  </p>
<%- end %>
