<%= f.inputs do %>
  <%= f.error_messages %>

  <%= f.input :name %>
  <%= f.input :production_code %>
  <%= f.input :credit_lines, :input_html=> { :rows => 3 } %>
  <%= f.input :first_preview_at %>
  <%= f.input :press_opening_at %>
  <%= f.input :opening_at %>
  <%= f.input :closing_at %>
  <%= f.input :show_description, :input_html=>{ :rows=>6}%>
  <%= f.input :running_time, :label=>"Running Time (in minutes)" %>
  <%= f.input :intermission %>
  <%= f.input :logo_url %>
  <%= f.input :capacity %>
  <%= f.input :additional_information_link, :as=>:url %>
  <%= f.input :status, :as=>:select, :collection=>Production::PRODUCTION_STATUSES, :include_blank=>false %>
  <%= f.input :flex_pass_offer, :collection=>f.object.theater.flex_pass_offers, :label=>"Festival Pass Offer" %>
  <%= f.input :myemma_attendee_group, :label=>"MyEmma Group Number" %>
  <%= f.input :follow_up_message, :input_html=>{:rows => 6} %>
<%- end -%>
