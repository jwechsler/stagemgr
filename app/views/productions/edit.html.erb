<h1>Editing production</h1>

<% form_for([@production.theater, @production]) do |f| %>
  <%= render :partial => 'form', :locals=>{:f=>f} %>
  <p>
    <%= f.submit 'Update' %>
  </p>
<% end %>

<%= link_to 'Show', [@production.theater, @production] %> |
<%= link_to 'Back', theater_productions_path(@production.theater) %>