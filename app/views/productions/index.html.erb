<h1>Listing productions</h1>

<table>
  <tr>
    <th>Name</th>
    <th>Credit lines</th>
    <th>First preview at</th>
    <th>Press opening at</th>
    <th>Opening at</th>
    <th>Closing at</th>
    <th>Show description</th>
    <th>Capacity</th>
    <th>Additional information link</th>
    <th>Status</th>
  </tr>

<% @productions.each do |production| %>
  <tr>
    <td><%=h production.name %></td>
    <td><%=h production.credit_lines %></td>
    <td><%=h production.first_preview_at %></td>
    <td><%=h production.press_opening_at %></td>
    <td><%=h production.opening_at %></td>
    <td><%=h production.closing_at %></td>
    <td><%=h production.show_description %></td>
    <td><%=h production.capacity %></td>
    <td><%=h production.additional_information_link %></td>
    <td><%=h production.status %></td>
    <td><%= link_to 'Show', [production.theater, production] %></td>
    <td><%= link_to 'Edit', edit_theater_production_path(production.theater, production) %></td>
    <td><%= link_to 'Destroy', [production.theater, production], :confirm => 'Are you sure?', :method => :delete %></td>
  </tr>
<% end %>
</table>

<br />

<%= link_to 'New production', new_theater_production_path(@theater) %>