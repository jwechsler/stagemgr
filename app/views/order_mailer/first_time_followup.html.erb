<% content_for :email_title do %>
 <%- if @order.performance.production.theater.is_default? %>
            Thanks for coming by to see <i><%= @order.performance.production.name %></i>.
          <%- else %>
            Thanks for coming by to see <i><%= @order.performance.production.name %>,</i>
            presented by <%= @order.performance.production.theater.name %>.
          <%- end %>
<% end %>
<p>
  I hope you had a good evening and will return soon (there are a few suggestions in the sidebar on the right, but check our website for all upcoming events).
</p><p>
  I'd like to take this opportunity to invite you back to Theater Wit.
  There's a ton happening here, some of which are listed in the sidebar to the right, and I hope you'll have a chance to check out some more.
</p>

<%= render :partial=>'core_followup', :locals=>{:order=>@order} %>

