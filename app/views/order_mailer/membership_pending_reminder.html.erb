<h2>Unfulfilled Membership orders</h2>
<table border="1">
  <thead>
    <tr>
      <th>Order ID</th>
      <th>Name</th>
      <th>Member Code</th>
    </tr>
  </thead>
  <%- @membership_orders.each do |order| %>
    <tr>
      <td><%= order.id %></td>
      <td><%= order.address.first_name %> <%= order.address.last_name %>
        <br/>
        <%= order.address.line1 %>
        <br/>
        <%- unless order.address.line2.blank? %>
          <%= order.address.line2 %>
          <br/>
        <%- end %>
        <%= order.address.city %>, <%= order.address.state %>  <%= order.address.zipcode %>
      </td>

      <td><%= order.membership.member_code %></td>
    </tr>
  <%- end %>

</table>