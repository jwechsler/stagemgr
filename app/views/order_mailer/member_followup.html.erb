<% content_for :email_title do %>
 Good to see you
<% end %>
<table class="w410" width="410" cellpadding="0" cellspacing="0" border="0">
  <tbody>
    <tr>
      <td class="w410" width="410">
        <p align="left" class="article-title">
          <% if @order.performance.production.theater.is_default? %>
            Thanks for coming by to see <i><%= @order.performance.production.name %></i>.
          <% else %>
            Thanks for coming by to see <i><%= @order.performance.production.name %>,</i>
            presented by <%= @order.performance.production.theater.name %>.
          <% end %>
        </p>
      </td>
    </tr>
    <tr>
      <td class="w410" width="410" height="10">
        <div align="left" class="article-content">
          <p>
            As a member, you are a core part of our
            community, both as audience and supporters of small theatre in Chicago.
          </p>
        </div>
      </td>
    </tr>
  </tbody>
</table>

<%= render :partial=>'core_followup', :locals=>{:order=>@order} %>
