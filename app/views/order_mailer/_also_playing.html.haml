%h6 Also playing at the Wit…
- productions = Production.additional_upcoming(order)
- productions.each do |prod|
  %table.spacer
    %tr
      %td.center.panel
        %span.production_name
          %a{:href=>url_for(controller:'performances',:production_id=>prod.id, :only_path=>false)}
            =prod.name
        %br
        - if prod.promo.attached?
          %span{:style=>'width:100%; height:100%; display: flex; align-items: center; justify-content: center;'}
            %a{:href=>url_for(controller:'performances',:production_id=>prod.id, :only_path=>false), :align=>'center'}
              %img{:src=>"#{prod.decorate.promo_url(Production::THUMB)}",:width=>"100%"}
        - unless prod.short_description.blank?
          %span.tag_line= prod.short_description
          %br
        %span.producing_company= prod.theater.name
        %br
        .slug
          - if prod.now_playing?
            Closes
            = prod.closing_at.to_s(:short)
          - else
            Starts
            = prod.first_preview_at.to_s(:short)
        %br

