.row.line_item{:price=>f.object.ticket_class.try(:ticket_price), :ticket_type=>f.object.ticket_class.try(:ticket_type)}
  .small-6.columns.vertical-center
    = f.hidden_field :ticket_class_id
    = f.object.ticket_class.class_name
  .small-6.medium-3.columns
    = f.select :ticket_count, 0.upto(20).map{|x| x}
  .small-12.medium-3.columns.vertical-center
    - if f.object.ticket_class.ticket_type == 'Donation'
      = f.input_field :price_override, :class=>'price_override', :placeholder=>"Suggested #{number_to_currency(f.object.ticket_class.ticket_price)}"
    -else
      - if f.object.ticket_class.software_managed
        n/a
      -else
        = number_to_currency(f.object.ticket_class.ticket_price)
  - unless f.object.ticket_class.purchase_page_annotation.blank?
    .small-12.columns.ticket_class_annotation
      = display_markdown(f.object.ticket_class.purchase_page_annotation)
