<% javascript :defaults, 'delegate', 'jquery-1.3.2.min', 'jquery.autocomplete', 'box_office_order' %>

Order for <%=@order_for_to_s%>

<% form_for(@order) do |order_form| %>
<%= order_form.error_messages %>
<%= order_form.hidden_field :production_code %>
<%= order_form.hidden_field :performance_code %>
<%= order_form.hidden_field :status %>
<%= hidden_field_tag 'order_phase', 'confirm' %>
<p>
<% order_form.fields_for :address do |address_form| %>
	<table border="0">
	<tr><td><%= address_form.label :first_name %><br/>
	<%= address_form.text_field :first_name %>
	</td><td><%= address_form.label :last_name %><br/>
	<%= address_form.text_field :last_name %>
	</td></tr></table>
	</p>
	<p>
	<%= address_form.label :email %><br/>
	<%= address_form.text_field :email %>
	</p>
	<p>
	<%= address_form.label :phone %><br/>
	<%= address_form.text_field :phone %>
	</p>
	<p>
	<%= address_form.label :line1, 'Billing Address' %><br/>
	<%= address_form.text_field :line1 %></p>
	<p>
	<table border="0">
	  <tr><td >
	<%= address_form.label :city, 'City' %><br />
	<%= address_form.text_field :city %></td>
	<td>
	<%= address_form.label :state, 'State' %><br/>
	<%= address_form.text_field :state, :size=>3 %>
	</td><td>
	<%= address_form.label :zipcode, 'Postal Code' %><br/>
	<%= address_form.text_field :zipcode, :size=>11 %>
	</td></tr></table>
<% end %>

<%- if @order.ticket_line_items.size > 0 -%>
<% some_are_donation = @order.line_items.any?{|li|li.ticket_class.ticket_type=='Donation'}%>
<table id='line_items'>
  <thead>
	<th>Type</th>
    <th>How many?</th>
	<th>Price</th>
<% javascript :defaults, 'delegate', 'jquery-1.3.2.min', 'jquery.autocomplete', 'box_office_order' %>

<% if some_are_donation %>
	<th>Suggested Donation</th>
	<th>Actual Donation(if different)</th>
<% end %>
    <th></th>
  </thead>
<% order_form.fields_for :ticket_line_items do |line_item_form| %>
<%= render :partial => '/orders/line_item', :locals => { :f => line_item_form, :some_are_donation => some_are_donation } %>
<% end %>
</table>
<%- end -%>
<%- if @order.flex_pass_line_items.size > 0 -%>
<% order_form.fields_for :flex_pass_line_items do |flex_pass_line_item_form| %>

<p>
	Number of Tickets on Pass:
	<%= @flex_pass_offer.number_of_tickets %>
</p>

<p>
	Price of Pass:
	<%= to_currency(@flex_pass_offer.price) %>
</p>

<p>
	Quantity:
	<%= flex_pass_line_item_form.select :ticket_count, 1.upto(20) %>
	<%= flex_pass_line_item_form.hidden_field :flex_pass_offer_id %>
</p>

<%- end -%>
<%- end -%>

<%= render :partial=>'/orders/billing_form', :locals=>{:order_form=>order_form, :payment_types=>Order::PAYMENT_TYPES-['Cash']}%>

<p>
  <%- if @order.flex_pass_line_items.size == 0 -%>
  <%= order_form.label :special_offer_code %> (optional)<br/>
  <%= order_form.text_field :special_offer_code %>  
  <%- end -%>
</p>
<!-- p>
  <%= order_form.label :referral_code %> (optional)<br/>
  <%= order_form.text_field :referral_code %>  
</p -->
  <p>
	<%= order_form.submit 'Order tickets', :disable_with => 'Processing...' if order_form.object.status == Order::NEW || order_form.object.status == Order::HOLD %>
  </p>
<br clear="all" />
<p>
</p>
<% end %>
