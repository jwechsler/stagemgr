<p>
Performance:
<%=order.performance.to_s %>
</p>

<table id='line_items'>
	<thead>
	<th>Ticket Class</th>
	<th>Ticket Count</th>
	</thead>
<% order.line_items.each do |line_item| %>
<% if line_item.ticket? then %><tr>
	<td><%=h line_item.ticket_class.to_s %></td>
	<td><%=h line_item.ticket_count %></td>
	</tr><% end %>
<% end %>
  <tr>
    <td></td>
    <td><%= order.line_items.map{|li|li.ticket? ? li.ticket_count : 0}.sum %> -- Total Tickets</td>
  </tr>
</table>

<h3>
Payments
</h3>
<table id='payments'>
  <thead>
   <th>id                      </th>
   <th>amount                  </th>
   <th>last_four          </th>
   <th>card               </th>
   <th>exp year    </th>
   <th>exp month   </th>
   <th>conf code       </th>
   <th>linked id              </th>
   <th>type                    </th>
   <th>created              </th>
  </thead>
  <% order.payments.each do |payment| %>
  <tr>
  <td><%= payment.id                      %></td>
  <td><%= to_currency(payment.amount)                  %></td>
  <td><%= payment.card_last_four          %></td>
  <td><%= payment.card_type               %></td>
  <td><%= payment.card_expiration_year    %></td>
  <td><%= payment.card_expiration_month   %></td>
  <td><%= payment.confirmation_code       %></td>
  <td><%= payment.payment_id              %></td>
  <td><%= payment.type                    %></td>
  <td><%= payment.created_at              %></td>
  </tr>
  <% end %>
</table>
<p>
	Order Status: 
	<%=h order.status %>
</p>
<p>
	Confirmation Code:
	<%=h order.payments.first.nil? ? "" : order.payments.first.confirmation_code %>
</p>
<p>
	Referral Code:
	<%=h order.referral_code %>
</p>
<p>
	Notes:
	<%=h order.notes %>
</p>
