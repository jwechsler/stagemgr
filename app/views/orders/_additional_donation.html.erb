<fieldset class="callout" style="border: 1px solid #000000; margin-left: 25%; padding: 5px;"><legend>I wish to offer additional support</legend>
  <%- t = order_form.object.performance.production.theater unless order_form.object.performance.nil?
      if t.blank? || t.theater_class == 'Default' -%>
    Yes! I love Theater Wit. Please add a tax-deductible contribution to this order. $
  <%- else -%>
  In addition to it's own award-winning programming, Theater Wit provides facilities and artistic support for groups like <%= t.name.strip %>. Help us bring theater, laughter and debate to our community. Add a tax-deductible contribution to this order. $
  <%- end -%>  <%= order_form.text_field :additional_donation, :size=>7 %>
</fieldset>
