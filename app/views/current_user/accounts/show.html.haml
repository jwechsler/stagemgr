-unless @user.is_box_office_user?
  =render partial: "producer_dailys", locals: {user: @user, rate_of_sales: @rate_of_sales, gross_sales_data: @gross_sales_data, theater_sales_data: @theater_sales_data, weekly_sales_data: @weekly_sales_data}
-if @user.is_box_office_user? || @user.is_administrator?
  =render partial: "box_office_dailys", locals: {user: @user, rate_of_sales: @rate_of_sales, gross_sales_data: @gross_sales_data, theater_sales_data: @theater_sales_data}
-if @user.is_theater_user? || @user.is_administrator?
  =render partial: "house_counts", locals: {house_counts: @house_counts}

%fieldset.fieldset
  %legend User Info
  .grid-x.grid-padding-x
    .small-8.cell
      %p
        %strong Email
        = @user.email
      = link_to 'Edit', edit_current_user_account_path, :class=>'button'
    .small-4.cell
      .grid-x.grid-padding-x
        .cell.small-6
          %strong Login count:
          = @user.login_count
          %br
          %strong Last login on:
          = @user.last_login_at
          %br
          %strong Last login ip:
          = @user.last_login_ip
        .cell.small-6
          %strong Current login on:
          = @user.current_login_at
          %br
          %strong Current login ip:
          = @user.current_login_ip

