<h1>Editing theater</h1>

<% form_for([:current_user,@theater], :html => { :multipart => true }) do |f| %>
  <%= render :partial => '/theaters/form', :locals=>{:f=>f} %>
<p>
  <%= f.submit 'Save' %>
</p>
<% end %>

<%= render :partial => '/theaters/productions' %>

<p>
  <%= link_to 'Add production', new_current_user_theater_production_path(@theater) %>
</p>

<%= link_to 'Back', current_user_theaters_path %>