<h1>Listing theaters</h1>

<table>
  <tr>
    <th>Name</th>
    <th>Url</th>
    <th>Logo</th>
    <th>Theater class</th>
    <th>Status</th>
  </tr>

<% @theaters.each do |theater| %>
  <tr>
    <td><%=link_to theater.name, edit_current_user_theater_path(theater) %></td>
    <td><%=h theater.url %></td>
    <td><%=image_tag theater.logo.url %></td>
    <td><%=h theater.theater_class %></td>
    <td><%=h theater.status %></td>
    <td><%= link_to 'Destroy', current_user_theater_path(theater), :confirm => 'Are you sure?', :method => :delete %></td>
  </tr>
<% end %>
</table>

<br />

<%= link_to 'New theater', new_current_user_theater_path %>
