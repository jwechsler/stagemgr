%p
  Recurring payments for Order #{link_to @order.id, admin_order_url(@order), :only_path=>false} have been suspended.
%p
  %table
    %tr
      %th{:width=>"40%"}
        Owner
      }
      %th{:width=>"20%"}
      %th{:width=>"30%"}
        Profile
      }
    %tr
      %td{:width=>"40%",:valign=>"top"}
        %div.grid-x.grid-padding-x
          %div.small-12.cell
            - address = @order.address
            -if address.nil?
              %b UNKNOWN ADDRESS
            - else
              %p
                = link_to address.full_name, admin_address_url(address)
                %br
                - unless address.line1.blank?
                  = address.line1
                  - unless address.line2.blank?
                    %br
                    = address.line2
                  %br
                - unless address.city.blank?
                  = "#{address.city}, #{address.state} #{address.zipcode}"
                - unless address.email.blank?
                  = mail_to address.email
                - unless address.phone.blank?
                  Phone: #{address.phone}
                  %br
                - memberships = Membership.find_all_by_address_id(address.id).select{|m| m.active?}
                - unless memberships.count == 0
                  %i Member ID:
                  = memberships.map {|m| m.member_code }.join(',')
      %td{:width=>"20%"}

      %td{:width=>"30%",:valign=>"top"}
        %p
          = @order.description
        %p
          Profile ID:
          %a{:href=>PaymentProcessing.subscription_url(@order.recurring_profile.profile_id)} #{@order.recurring_profile.profile_id}
          %br
          Last Billing Date:
          =@order.recurring_profile.next_billing_date.to_s
          
