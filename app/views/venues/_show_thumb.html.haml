:css
  #nowplaying_thumb_#{production.id} {
    background: url(#{production.decorate.promo_url(Production::THUMB)}) no-repeat center center;
    display:block;
    overflow:hidden;
    white-space:nowrap;
    text-indent:100%;
    height: 186px;
  }

%div{:class=>"show-listing background-#{background} cell small-12 medium-#{(slice*12.0/100).round}"}
  %p
    %div.venue= production.venue.name
    %p.centered= link_to(production.decorate.promo(Production::THUMB), production_performances_path(production.id))
    - link_to("showtitle", production_performances_path(production.id, :anchor=>"top"), id:"nowplaying_thumb_#{production.id}") if production.promo.attached?
    %div.production_name
      - if (defined? new_window_link) && new_window_link
        = link_to production.name, production_performances_path(production.id), :target=>'_blank'
      - else
        = link_to(production.name, production_performances_path(production.id, :anchor=>"top"))
    - unless production.short_description.blank?
      = "#{production.short_description}"
      <br>

    - if !production.theater.is_default?
      %div.presenter= "presented by #{production.theater.name}"
    - else
      %div.presenter= production.theater.name
    - unless production.theater.is_default?
      %div.company_class= production.theater.theater_class
    -# Thumbs only surface here when the show rides the regular venue flow
    -# (a festival's lone remaining show); grouped members render in the
    -# festival block, which carries its own branding.
    - if production.festival&.active?
      %div.production_festival_note= "Part of the #{production.festival.name}"
