.row
  .small-12.columns
    %fieldset
      %legend Tickets
      .row
        .small-12.medium-12.columns
          = render partial: '/ticket_orders/seating', locals: {ticket_order: order, order_form: order_form}
        .small-12.medium-6.columns
          &nbsp;
      .row
        .small-12.columns
          = render '/orders/special_offer_form', :f => order_form, :special_offer_code=>order.special_offer_code

<!-- custom javascript -->
= content_for :js do
  = javascript_include_tag 'orders_common'
  :javascript
    jQuery(document).ready(function($) {
      setup_totals(false);
    });

