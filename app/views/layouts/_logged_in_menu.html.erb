<% if current_user.is_theater_user? then %>
  <% Theater.all.select{|t| current_user.theater_ids.include?(t.id) }.each {|t| %>
    <%= link_to t.name, admin_theater_path(t) %> | <%-  } -%>
<%- elsif permitted_to? :view, :admin_theaters then -%>
    <%= link_to('Theaters',admin_theaters_path) %> |
<%- end -%>

<% permitted_to? :edit, :admin_users do %>
    <%= link_to('Users',admin_users_path) %>  |
<% end %>

<% if current_user.is_administrator %>
	<%= link_to('Administer Users', admin_users_path) %> |
<% end %>
<%= link_to('New Ticket Order', new_admin_order_path) %> |
<%- permitted_to? :view, :admin_orders do -%>
    <%= link_to('Existing Orders', admin_orders_path) %> |
<%- end -%>
<% if current_user.is_administrator || current_user.is_box_office_user %>

	<%= link_to('Special Offers', admin_special_offers_path) %> |
<%- end -%>
<%- permitted_to? :view, :admin_flex_pass_offers do %>
	<%= link_to('Flex Pass Offers', admin_flex_pass_offers_path) %> |
<% end %>

<%= link_to('My Account', current_user_account_path) %> |
<%= link_to('Logout',logout_path, :method => :delete, :confirm => "Are you sure you want to logout?") %>