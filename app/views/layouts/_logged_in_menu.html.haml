.sticky
  %nav(class="top-bar" data-topbar data-options="sticky_on: large")
    %ul.title-area
      %li.name
        %h1
          %a{:href=>"#"}
            StageMgr
      -# Remove the class "menu-icon" to get rid of menu icon. Take out "Menu" to just have icon alone
      %li.toggle-topbar.menu-icon
        %a{:href=>"#"}>
          %span Menu

    %section.top-bar-section
      / Right Nav Section
      %ul.left
        - if current_user.is_theater_user? then
          %li.has-dropdown
            %a{:href=>"#"} Your Theaters
            %ul.dropdown
              - Theater.where("id in (?)",current_user.theater_ids).each do |t|
                %li
                  =link_to t.name, admin_theater_path(t)
        - elsif can? :read, Theater then
          %li
            =link_to('Theaters',admin_theaters_path)

        - if can? :read, Order
          %li
            =link_to('Existing Orders', admin_orders_path)
        - if can?(:read, MembershipOffer) || can?(:read, FlexPassOffer)
          %li.has-dropdown
            %a{:href=>"#"} Passes
            %ul.dropdown
              - if can? :read, MembershipOffer
                %li
                  =link_to('Membership Offers', admin_membership_offers_path)

              - if can? :read, FlexPassOffer
                %li
                  =link_to('Flex Pass Offers', admin_flex_pass_offers_path)
        %li
          =link_to('Reports', admin_reports_path)
        %li.has-dropdown
          %a{:href=>"#"} Options
          %ul.dropdown
            - if can? :edit, SpecialOffer
              %li
                =link_to('Special Offers', admin_special_offers_path)
            - if (can? :edit, User) || (can? :edit, SpecialFeature) || (can? :edit, DefaultTicketClass) || (can? :edit, PaymentType) || (can? :read, FileStore) || (can? :edit, Venue)
              %li
                %label System Config
                - if can? :read, User
                  %li
                    =link_to('Administer Users', admin_users_path)
                - if can? :read, SpecialFeature
                  %li
                    =link_to('Performance Features', admin_special_features_path)
                - if can? :read, DefaultTicketClass
                  %li
                    =link_to 'Default Ticket Classes', admin_default_ticket_classes_path
                - if can? :read, PaymentType
                  %li
                    =link_to "Manage Payment Types", admin_payment_types_path
                - if (can? :edit, Venue) then
                  %li= link_to('Venues', admin_venues_path)
                - if (can? :edit, ServiceItemTemplate) then
                  %li= link_to('Service Items', admin_service_item_templates_path)
                - if can? :read, FileStore
                  %li.divider
                  %li
                    =link_to "Import data", admin_imports_path

        %li
          =link_to('My Account', current_user_account_path)
        %li
          =link_to('Logout',logout_path, :method => :delete, :confirm => "Are you sure you want to logout?")
      %ul.right
        %li.has_form
          =link_to('New Ticket Order', new_admin_ticket_order_path, class:"button")


