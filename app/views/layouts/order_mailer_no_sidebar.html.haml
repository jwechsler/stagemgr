!!! Strict
%html
  %head
    %meta{'http-equiv'=>'Content-Type', :content=>"text/html; charset=utf-8"}
    %meta{:name=>"viewport", :content=>"width=device-width"}
    %title
      <%= yield :email_title %>
    =render 'foundation_email_css'

  %body
    <!-- <style> -->
    %table.body{:data-made-with-foundation=>""}
      %tr
        %td.float-center{:align=>"center",:valign=>"top"}
          %center{'data-parsed'=>''}
            %table.spacer.float-center
              %tbody
                %tr
                  %td{:height=>"16px", :style=>"font-size:16px;line-height:16px;"} &#xA0;

            %table.wrapper.header.float-center{:bgcolor=>"#f3f3f3", :align=>"center"}
              %tr
                %td.wrapper-inner
                  %table.container{:align=>"center"}
                    %tbody
                      %tr
                        %td
                          %table.row.collapse
                            %tbody
                              %tr
                                - if @order.theater.nil? || @order.theater.producing? || @order.theater.best_logo_url_available(:medium).blank?
                                  %th.small-12.columns.first{:valign=>'middle'}
                                    %table
                                      %tr
                                        %td.vhcenter
                                          %img{:src=>"https://www.theaterwit.org/static/img/logo_color_small_tagless.png"}
                                - else
                                  %th.small-6.large-6.columns.first{:valign=>"middle"}
                                    %table
                                      %tr
                                        %td.vhcenter
                                          %img{:src=>"https://www.theaterwit.org#{@order.theater.best_logo_url_available(:medium)}"}
                                  %th.small-6.large-6.columns.last{:valign=>"middle"}
                                    %table
                                      %tr
                                        %th.vhcenter
                                          %img{:src=>"http://www.theaterwit.org/static/img/logo_color_small_tagless.png"}

            %table.container.float-center{:align=>"center"}
              %tbody
                %tr
                  %td
                    %table.spacer
                      %tbody
                        %tr
                          %td{:height=>"16px", :style=>"font-size:16px;line-height:16px;"} &#xA0;
                        %tr
                          %td{:style=>"padding:0px 8px 0px 8px"}
                            %h1
                              =yield :email_title
                    %table.row
                      %tbody
                        %tr
                          %th.small-12.columns.first
                            %table
                              %tr
                                %th

                                  =yield


