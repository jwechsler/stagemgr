-# Foundation 6 callout wrapped as a partial.
-#
-# Usage:
-#   = render "shared/components/callout", variant: "warning" do
-#     Body content goes here.
-#
-#   = render "shared/components/callout", variant: color, style: "margin-top:0.5rem" do
-#     ...
-#
-# variant: secondary | primary | success | warning | alert. May be a dynamic
-#          value. Defaults to "secondary".
-# style:   optional inline style string (attribute omitted when absent).

- variant = local_assigns.fetch(:variant, "secondary")
- attrs = { class: variant }
- attrs[:style] = local_assigns[:style] if local_assigns[:style].present?
.callout{ attrs }
  = yield
