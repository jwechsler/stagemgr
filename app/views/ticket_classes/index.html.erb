<h1>Listing ticket_classes</h1>

<table>
  <tr>
    <th>Class code</th>
    <th>Price</th>
  </tr>

<% @ticket_classes.each do |ticket_class| %>
  <tr>
    <td><%=h ticket_class.class_code %></td>
    <td><%=h ticket_class.price %></td>
    <td><%= link_to 'Show', ticket_class %></td>
    <td><%= link_to 'Edit', edit_ticket_class_path(ticket_class) %></td>
    <td><%= link_to 'Destroy', ticket_class, :confirm => 'Are you sure?', :method => :delete %></td>
  </tr>
<% end %>
</table>

<br />

<%= link_to 'New ticket_class', new_ticket_class_path %>