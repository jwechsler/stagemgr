- if file_stores.size > 0
  %table
    %thead
      %th Created On
      %th File Name
      %th Size
      %th Status
    %tbody
      - file_stores.each do |file|
        %tr
          %td= file.created_at.to_s
          %td= link_to file.data.filename.base, url_for(file.data)
          %td= file.data.byte_size.nil? ? '' : "#{file.data.byte_size/1024} KB"
          %td= file.notes
