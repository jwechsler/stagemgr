- if file_stores.size > 0
  %table
    %thead
      %th Created On
      %th File Name
      %th Size
      %th Status
    %tbody
      - file_stores.each do |file|
        %tr
          %td= file.created_at.to_s
          %td= file.decorate.datafile
          %td= file.datafile.byte_size.nil? ? '' : "#{file.datafile.byte_size/1024} KB"
          %td= file.notes
