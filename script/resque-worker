#!/bin/bash

case "$1" in
  start)
    if [[ "$RAILS_ENV" == "production" ]] ; then
      nohup bundle exec rake environment resque:work PIDFILE=./resque.pid QUEUE=notification,report,maintenance,import >> log/resque.log 2>&1 &
      nohup bundle exec rake environment resque:work PIDFILE=./resque-sync.pid QUEUE=sync >> log/sync.log 2>&1 &
    else
      nohup bundle exec rake environment resque:work PIDFILE=./resque.pid QUEUE="*" >> log/resque.log 2>&1 &
    fi
    ;;
  stop)
    kill `cat ./resque.pid`
    if [ $? -eq 0 ]; then
      rm ./resque.pid
      echo "Resque worker #1 stopped"
    fi
    kill `cat ./resque-sync.pid`
    if [ $? -eq 0 ]; then
      rm ./resque-sync.pid
      echo "Resque worker #2 stopped"
    fi

    ;;
esac
