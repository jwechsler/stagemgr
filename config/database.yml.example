# SQLite version 3.x
#   gem install sqlite3-ruby (not necessary on OS X Leopard)
development:
  adapter: mysql2
  database: stagemgr_development
  username: root
  password:
  socket: /tmp/mysql.sock

# The test/cucumber suites run on MySQL (not sqlite). Values are ENV-driven so
# the same template works locally and in CI (which sets DATABASE_HOST etc. to
# point at its ephemeral MySQL service).
# Do not set this db to the same as development or production.
test: &TEST
  adapter: mysql2
  encoding: utf8mb4
  database: <%= ENV.fetch("TEST_DATABASE", "stagemgr_test") %>
  username: <%= ENV.fetch("DATABASE_USERNAME", "root") %>
  password: <%= ENV.fetch("DATABASE_PASSWORD", "") %>
  host: <%= ENV.fetch("DATABASE_HOST", "127.0.0.1") %>
  port: <%= ENV.fetch("DATABASE_PORT", 3306) %>
  pool: 5

production:
  adapter: sqlite3
  database: db/production.sqlite3
  pool: 5
  timeout: 5000

cucumber:
  <<: *TEST
