# Stagemgr environment configuration.
# Copy this file to .env and fill in real values. The .env file is gitignored.
# In Docker the same file is read by docker compose and by the Rails app inside the container.

# ─── Database (required) ───────────────────────────────────────────────────────
DATABASE_USER=stagemgr_dev
DATABASE_PASSWORD=password
DATABASE_HOST=mysql               # use 127.0.0.1 when running natively
DATABASE_PORT=3306
DATABASE_NAME=stagemgr_dev

# ─── Redis (required) ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0    # use redis://127.0.0.1:6379/0 when running natively

# ─── Rails (required) ──────────────────────────────────────────────────────────
RAILS_ENV=development
# Generate with: bundle exec rails secret
SECRET_KEY_BASE=

# ─── Stripe payment processing ─────────────────────────────────────────────────
# Test keys begin with pk_test_/sk_test_; live keys with pk_live_/sk_live_.
# Webhook signing secret begins with whsec_.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_SECRET=

# ─── Postmark transactional email (optional) ───────────────────────────────────
# If unset and config/server.yml's delivery_method is 'postmark', mail sends fail.
POSTMARK_API_TOKEN=

# ─── MyEmma mailing list (optional) ────────────────────────────────────────────
# If MY_EMMA_ACCOUNT_ID is empty, MyEmma runs in read-only mode in development
# and is disabled in production.
MY_EMMA_USERNAME=
MY_EMMA_PASSWORD=
MY_EMMA_ACCOUNT_ID=

# ─── PayPal (legacy, optional) ─────────────────────────────────────────────────
# Only used when config/server.yml's default_gateway is set to 'paypal' or
# 'paypal_express'. Stripe is the current default.
PAYPAL_LOGIN=
PAYPAL_PASSWORD=
PAYPAL_SIGNATURE=
PAYPAL_PEM_FILE=
PAYPAL_EXPRESS_LOGIN=

# ─── ActiveStorage cloud backends (optional) ───────────────────────────────────
# Uncomment storage.yml's amazon: block to enable. Leave blank to use local disk.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AZURE_STORAGE_ACCESS_KEY=
