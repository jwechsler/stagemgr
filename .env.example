# Stagemgr environment configuration.
# Copy this file to .env and fill in real values. The .env file is gitignored.
# Both `docker compose` and `dotenv-rails` read it from the project root.

# ═════════════════════════════════════════════════════════════════════════
# Required
# ═════════════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_USER=stagemgr_dev
DATABASE_PASSWORD=password
DATABASE_HOST=mysql               # 127.0.0.1 for native; compose overrides to "mysql"
DATABASE_PORT=3306
DATABASE_NAME=stagemgr_dev
# DATABASE_POOL=5                 # only override if you tune Rails thread pool

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0    # redis://127.0.0.1:6379/0 for native

# ─── Rails ─────────────────────────────────────────────────────────────────────
RAILS_ENV=development
# Generate with: bundle exec rails secret
SECRET_KEY_BASE=

# ═════════════════════════════════════════════════════════════════════════
# Payment processing
# ═════════════════════════════════════════════════════════════════════════

# Stripe test keys begin with pk_test_/sk_test_; live keys with pk_live_/sk_live_.
# Webhook signing secret begins with whsec_.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_SECRET=

# Legacy PayPal — only used when config/server.yml's default_gateway is
# 'paypal' or 'paypal_express'. Stripe is the current default.
PAYPAL_LOGIN=
PAYPAL_PASSWORD=
PAYPAL_SIGNATURE=
PAYPAL_PEM_FILE=
PAYPAL_EXPRESS_LOGIN=

# ═════════════════════════════════════════════════════════════════════════
# Optional integrations
# ═════════════════════════════════════════════════════════════════════════

# Postmark — required if config/server.yml sets email.delivery_method: postmark.
# The from-address itself lives in config/server.yml under email.addresses.
POSTMARK_API_TOKEN=

# MyEmma mailing list — all three values are required. If any one is blank,
# MyEmma is disabled (in test, dev, and prod alike) and integration code paths
# short-circuit via MyEmma.disabled?.
MY_EMMA_USERNAME=
MY_EMMA_PASSWORD=
MY_EMMA_ACCOUNT_ID=

# ActiveStorage cloud backends — uncomment the matching block in
# config/storage.yml. Leave blank to use local disk storage.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AZURE_STORAGE_ACCESS_KEY=

# ═════════════════════════════════════════════════════════════════════════
# setup:wizard non-interactive mode
# ═════════════════════════════════════════════════════════════════════════
# When these are set, `bundle exec rake setup:create_admin` (and the full
# `setup:wizard`) skip the email/password prompt and use these values.
# Leave blank to be prompted interactively.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ═════════════════════════════════════════════════════════════════════════
# Production tuning
# ═════════════════════════════════════════════════════════════════════════
# These only matter in production (or when you want production-like behavior
# locally). Leave commented for normal development.

# RAILS_SERVE_STATIC_FILES=true   # serve public/ from Rails (vs an Nginx alias)
# RAILS_LOG_TO_STDOUT=true        # write logs to stdout for the Docker/journald
                                  # log driver instead of log/production.log

# Puma tuning (native installs only — the Docker image runs Passenger).
# RAILS_MAX_THREADS=5
# PORT=3000

# ═════════════════════════════════════════════════════════════════════════
# Docker compose overrides
# ═════════════════════════════════════════════════════════════════════════
# Host-side port mappings. Override if something else is already bound to
# the default.

# STAGEMGR_HOST_PORT=8080
# MYSQL_HOST_PORT=3306
# REDIS_HOST_PORT=6379

# Foundation marketing-site profile (docker compose --profile frontend up).
# FOUNDATION_REPO_PATH=../foundation
# FOUNDATION_HOST_PORT=8000
