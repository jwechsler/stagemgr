#!/usr/bin/env ruby

ENV["RAILS_ENV"] ||= ENV["RACK_ENV"] || "development"
ENV["NODE_ENV"]  ||= "development"

# webpack 4 (shipped with webpacker 5.4) uses MD4 for build hashes, which
# OpenSSL 3 (Node 17+) refuses by default. Restore legacy provider support
# so the child node process can hash. Idempotent if Node is older.
ENV["NODE_OPTIONS"] = "#{ENV['NODE_OPTIONS']} --openssl-legacy-provider".strip

require "pathname"
ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../../Gemfile",
  Pathname.new(__FILE__).realpath)

require "bundler/setup"

# stdlib Logger must be loaded before webpacker triggers active_support/logger;
# this entry point bypasses config/boot.rb and config/application.rb, so the
# require lives here too.
require "logger"

require "webpacker"
require "webpacker/webpack_runner"

APP_ROOT = File.expand_path("..", __dir__)
Dir.chdir(APP_ROOT) do
  Webpacker::WebpackRunner.run(ARGV)
end
