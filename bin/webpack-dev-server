#!/usr/bin/env ruby

ENV["RAILS_ENV"] ||= ENV["RACK_ENV"] || "development"
ENV["NODE_ENV"]  ||= "development"

# Same workaround as bin/webpack: webpack 4 needs the OpenSSL 3 legacy
# provider for its MD4 build hash on Node 17+.
ENV["NODE_OPTIONS"] = "#{ENV['NODE_OPTIONS']} --openssl-legacy-provider".strip

require "pathname"
ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../../Gemfile",
  Pathname.new(__FILE__).realpath)

require "bundler/setup"

# Same reason as bin/webpack: this entry point bypasses config/boot.rb and
# config/application.rb, so we have to require stdlib Logger here before
# webpacker triggers active_support/logger.
require "logger"

require "webpacker"
require "webpacker/dev_server_runner"

APP_ROOT = File.expand_path("..", __dir__)
Dir.chdir(APP_ROOT) do
  Webpacker::DevServerRunner.run(ARGV)
end
